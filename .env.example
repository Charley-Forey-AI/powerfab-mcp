# PowerFab MCP Server — sample environment configuration.
#
# Copy this file to `.env` (which is gitignored) and fill in the real values.
# The server loads `.env` automatically at startup. Process / shell env vars
# always win over `.env`, so containers and Cursor can still override.
#
# Variable names use ASP.NET Core's double-underscore section separator
# (e.g. Powerfab__Username binds to Powerfab:Username in IConfiguration).

# --- PowerFab Remote Service connection (REQUIRED) ---------------------------

# External user created in PowerFab Office under External Users.
Powerfab__Username=

# Password for the External user above. Treat as a secret.
Powerfab__Password=

# Hostname or IP address of the PowerFab Remote Service.
Powerfab__RemoteHost=127.0.0.1

# TCP port of the PowerFab Remote Service.
Powerfab__RemotePort=8080

# Per-call timeout (HH:mm:ss). Optional; defaults to 60 seconds.
Powerfab__RequestTimeout=00:01:00

# Set to "all" to record every command in:
#   PowerFab → Maintenance → Integration Settings → API Log
# Leave empty to disable logging on the PowerFab side.
Powerfab__ApiLog=

# --- MCP HTTP transport (OPTIONAL — sane defaults already shipped) -----------

# Kestrel listen URL. Default is loopback only for safety.
# Use http://0.0.0.0:3000 (and put a TLS-terminating reverse proxy in front)
# to expose externally.
Hosting__BindUrl=http://127.0.0.1:3000

# MCP endpoint path. Cursor / Claude Desktop point at this URL.
Hosting__McpPath=/mcp

# When set, every MCP request must carry: Authorization: Bearer <token>
# REQUIRED whenever Hosting__BindUrl is bound to a non-loopback address.
Hosting__BearerToken=

# Comma-separated list of allowed Origin header values, e.g.:
#   https://cursor.example.com,https://internal-tools.example.com
# Loopback origins are auto-allowed when bound to loopback.
Hosting__AllowedOrigins=
